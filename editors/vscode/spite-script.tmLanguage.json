{
  "scopeName": "source.spite",
  "name": "SpiteScript",
  "fileTypes": ["spite"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#template-strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#attributes" },
    { "include": "#macros" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "match": "///.*$", "name": "comment.line.documentation.spite" },
        { "match": "//.*$", "name": "comment.line.double-slash.spite" },
        { "begin": "/\\*", "end": "\\*/", "name": "comment.block.spite" }
      ]
    },
    "strings": {
      "patterns": [
        { "begin": "\"", "end": "\"", "name": "string.quoted.double.spite",
          "patterns": [{ "match": "\\\\.", "name": "constant.character.escape.spite" }] },
        { "begin": "'", "end": "'", "name": "string.quoted.single.spite",
          "patterns": [{ "match": "\\\\.", "name": "constant.character.escape.spite" }] }
      ]
    },
    "template-strings": {
      "begin": "`", "end": "`", "name": "string.template.spite",
      "patterns": [
        { "begin": "\\$\\{", "end": "\\}", "name": "meta.template.expression.spite",
          "patterns": [{ "include": "$self" }] }
      ]
    },
    "numbers": {
      "patterns": [
        { "match": "\\b0x[0-9a-fA-F_]+\\b", "name": "constant.numeric.hex.spite" },
        { "match": "\\b0b[01_]+\\b", "name": "constant.numeric.binary.spite" },
        { "match": "\\b0o[0-7_]+\\b", "name": "constant.numeric.octal.spite" },
        { "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?(f32|f64)?\\b", "name": "constant.numeric.float.spite" },
        { "match": "\\b[0-9][0-9_]*(i8|i16|i32|i64|i128|u8|u16|u32|u64|u128)?\\b", "name": "constant.numeric.integer.spite" }
      ]
    },
    "keywords": {
      "patterns": [
        { "match": "\\b(let|mut|const|fn|return|if|else|match|for|in|while|loop|break|continue|struct|impl|trait|enum|as|pub)\\b", "name": "keyword.control.spite" },
        { "match": "\\b(and|or|not)\\b", "name": "keyword.operator.spite" },
        { "match": "\\b(true|false)\\b", "name": "constant.language.boolean.spite" },
        { "match": "\\b(self|Self)\\b", "name": "variable.language.spite" },
        { "match": "\\b(None|Some|Ok|Err)\\b", "name": "support.type.spite" }
      ]
    },
    "types": {
      "match": "\\b(i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f32|f64|bool|char|String|Map|Option|Result|Ref|Fn)\\b",
      "name": "support.type.primitive.spite"
    },
    "attributes": {
      "match": "@\\w+", "name": "meta.attribute.spite"
    },
    "macros": {
      "match": "\\b\\w+!", "name": "entity.name.function.macro.spite"
    },
    "operators": {
      "match": "\\|>|<=>|\\.\\.|\\.\\.=|=>|->|::|&&|\\|\\||[+\\-*/%=<>!&|^~?]",
      "name": "keyword.operator.spite"
    }
  }
}
